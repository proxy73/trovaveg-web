---
import {
  absoluteUrl,
  getLanguageSwitchHref,
  type AlternateKey,
  type AppCopy,
  type Locale,
  site,
} from '../content/copy';
import '../styles/global.css';

interface Props {
  locale: Locale;
  copy: AppCopy;
  title: string;
  description: string;
  canonicalPath: string;
  alternateKey: AlternateKey;
  noindex?: boolean;
}

const {
  locale,
  copy,
  title,
  description,
  canonicalPath,
  alternateKey,
  noindex = false,
} = Astro.props;

const pageTitle =
  title === site.name || title.startsWith('TrovaVeg')
    ? title
    : `${title} · ${site.name}`;
const canonicalUrl = absoluteUrl(canonicalPath);
const ogImageUrl = absoluteUrl(site.ogImage);
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const homeHref = locale === 'it' ? '/' : '/en';
const showHreflang = !noindex;
const switchItHref = getLanguageSwitchHref(alternateKey, 'it');
const switchEnHref = getLanguageSwitchHref(alternateKey, 'en');
const itAbs = absoluteUrl(switchItHref);
const enAbs = absoluteUrl(switchEnHref);
const ogLocale = copy.ogLocale;
const ogLocaleAlt = locale === 'it' ? 'en_US' : 'it_IT';
---

<!doctype html>
<html lang={copy.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {
      showHreflang && (
        <>
          <link rel="alternate" hreflang="it" href={itAbs} />
          <link rel="alternate" hreflang="en" href={enAbs} />
          <link rel="alternate" hreflang="x-default" href={absoluteUrl('/')} />
        </>
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />

    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${site.cloudflareAnalyticsToken}"}`}
    ></script>
  </head>
  <body>
    <a class="skip-link" href="#contenuto">{copy.ui.skipToContent}</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href={homeHref} aria-label="TrovaVeg" title="TrovaVeg">
          <img
            class="brand__logo"
            src="/logo.png"
            width="243"
            height="48"
            alt=""
          />
        </a>

        <button
          type="button"
          class="nav-toggle"
          id="nav-toggle"
          aria-controls="site-nav"
          aria-expanded="false"
        >
          <span class="nav-toggle__icon" aria-hidden="true"></span>
          <span class="nav-toggle__label">{copy.ui.menuLabel}</span>
        </button>

        <nav class="site-nav" id="site-nav" aria-label={copy.ui.navAriaLabel}>
          <ul class="nav">
            {
              copy.nav.map((item) => {
                const current =
                  item.href === '/' || item.href === '/en'
                    ? pathname === item.href
                    : pathname === item.href || pathname.startsWith(`${item.href}/`);
                return (
                  <li>
                    <a href={item.href} aria-current={current ? 'page' : undefined}>
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
            <li class="lang-switch">
              <span class="lang-switch__label" id="lang-switch-label">
                {copy.ui.languageLabel}
              </span>
              <ul class="lang-switch__list" aria-labelledby="lang-switch-label">
                <li>
                  <a
                    href={switchItHref}
                    lang="it"
                    hreflang="it"
                    aria-current={locale === 'it' ? 'page' : undefined}
                  >
                    {copy.ui.langIt}
                  </a>
                </li>
                <li>
                  <a
                    href={switchEnHref}
                    lang="en"
                    hreflang="en"
                    aria-current={locale === 'en' ? 'page' : undefined}
                  >
                    {copy.ui.langEn}
                  </a>
                </li>
              </ul>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="contenuto" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <p class="site-footer__brand">{site.name}</p>
          <p class="site-footer__meta">{copy.siteChrome.tagline}</p>
          <p class="site-footer__meta">{copy.siteChrome.description}</p>
          {
            'availability' in copy.siteChrome && copy.siteChrome.availability ? (
              <p class="site-footer__meta">{copy.siteChrome.availability}</p>
            ) : null
          }
        </div>
        <div class="site-footer__links">
          <a href={site.telegramBot}>
            {'footerCta' in copy.siteChrome && copy.siteChrome.footerCta
              ? copy.siteChrome.footerCta
              : copy.ui.footerBot}
          </a>
          <a href={site.instagram}>Instagram {site.instagramHandle}</a>
          <a href={site.facebook}>Facebook {site.facebookLabel}</a>
          {
            copy.nav
              .filter((item) => item.href !== '/' && item.href !== '/en')
              .map((item) => (
                <a href={item.href}>{item.label}</a>
              ))
          }
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </div>
        <p class="site-footer__note">{copy.ui.footerNote}</p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var toggle = document.getElementById('nav-toggle');
        var nav = document.getElementById('site-nav');
        if (!toggle || !nav) return;

        function setOpen(open) {
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          nav.classList.toggle('is-open', open);
          document.body.classList.toggle('nav-open', open);
        }

        function isOpen() {
          return toggle.getAttribute('aria-expanded') === 'true';
        }

        toggle.addEventListener('click', function () {
          setOpen(!isOpen());
        });

        nav.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            setOpen(false);
          });
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && isOpen()) {
            setOpen(false);
            toggle.focus();
          }
        });
      })();
    </script>
  </body>
</html>
