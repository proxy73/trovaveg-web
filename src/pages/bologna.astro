---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, bologna } from '../content/copy';
---

<BaseLayout
  title={bologna.title}
  description={bologna.lead}
  canonicalPath="/bologna"
>
  <header class="page-hero">
    <div class="page-hero__inner">
      <span class="page-hero__status">Soft launch</span>
      <h1>{bologna.headline}</h1>
      <p class="page-hero__lead">{bologna.lead}</p>
    </div>
  </header>

  <img
    class="screenshot"
    src="/images/screenshot-bot-placeholder.svg"
    width="560"
    height="720"
    alt="Anteprima placeholder della chat TrovaVeg su Telegram"
  />

  <div class="prose">
    {bologna.body.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  <div class="cta-row">
    <a class="btn btn--solid" href={site.telegramBot}>{bologna.cta}</a>
  </div>
</BaseLayout>
