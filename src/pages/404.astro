---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, notFound } from '../content/copy';
---

<BaseLayout
  title={notFound.title}
  description={notFound.lead}
  canonicalPath="/404"
  noindex={true}
>
  <div class="error-page">
    <div class="error-page__inner">
      <h1>{notFound.headline}</h1>
      <p>{notFound.lead}</p>
      <div class="hero__actions error-page__actions">
        <a class="btn btn--outline" href="/">{notFound.ctaHome}</a>
        <a class="btn btn--primary" href={site.telegramBot}>{notFound.ctaBot}</a>
      </div>
    </div>
  </div>
</BaseLayout>
