---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, firenze } from '../content/copy';
---

<BaseLayout title={firenze.title} description={firenze.lead} canonicalPath="/firenze">
  <header class="page-hero">
    <div class="page-hero__inner page-hero__inner--split">
      <div>
        <span class="page-hero__status">Beta</span>
        <h1>{firenze.headline}</h1>
        <p class="page-hero__lead">{firenze.lead}</p>
        <div class="hero__actions">
          <a class="btn btn--primary" href={site.telegramBot}>{firenze.cta}</a>
          <a class="btn btn--outline" href={site.telegramBot}>{firenze.signalCta}</a>
        </div>
      </div>
      <img
        class="phone-shot"
        src={firenze.image.src}
        width="738"
        height="1600"
        alt={firenze.image.alt}
        fetchpriority="high"
      />
    </div>
  </header>

  <div class="prose">
    {firenze.body.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  <section class="section section--tight" aria-labelledby="features-title">
    <div class="section__inner">
      <h2 id="features-title">{firenze.featuresTitle}</h2>
      <ul class="limits">
        {firenze.features.map((item) => <li>{item}</li>)}
      </ul>
      <div class="cta-band">
        <a class="btn btn--primary" href={site.telegramBot}>{firenze.cta}</a>
      </div>
    </div>
  </section>
</BaseLayout>
