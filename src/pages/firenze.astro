---
import CityView from '../components/CityView.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCopy, site } from '../content/copy';

const copy = getCopy('it');
---

<BaseLayout
  locale="it"
  copy={copy}
  title={copy.firenze.metaTitle}
  description={copy.firenze.metaDescription}
  canonicalPath="/firenze"
  alternateKey="florence"
>
  <CityView city={copy.firenze} site={site} />
</BaseLayout>
