---
import HomeView from '../components/HomeView.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCopy, site } from '../content/copy';

const copy = getCopy('it');
---

<BaseLayout
  locale="it"
  copy={copy}
  title={copy.home.metaTitle}
  description={copy.home.metaDescription}
  canonicalPath="/"
  alternateKey="home"
>
  <HomeView copy={copy} site={site} />
</BaseLayout>
